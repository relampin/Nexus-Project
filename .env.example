PORT=3000
PROCESSING_INTERVAL_MS=5000

# Pasta do proprio Nexus portatil
NEXUS_HOME=.

# Pasta raiz fixa da plataforma Nexus
# Use isso para apontar o Nexus principal, nao para trocar de projeto.
# Os projetos reais devem ser ligados pelo painel em settings.projectRoot.
NEXUS_PLATFORM_ROOT=..

# Alias legado mantido por compatibilidade.
TARGET_PROJECT_ROOT=

# Se quiser disparo automatico do lado Codex por OpenClaw
OPENCLAW_CLI=openclaw
OPENCLAW_AGENT=codexbridge
OPENCLAW_MODEL=openai-codex/gpt-5.4
OPENCLAW_THINKING=medium
OPENCLAW_TIMEOUT_MS=600000
OPENCLAW_WORKSPACE=
CODEX_WORKSPACE=

# Porta/localizacao da automacao do Antigravity
ANTIGRAVITY_CDP_ENDPOINT=http://127.0.0.1:9222
ANTIGRAVITY_CDP_PAGE_TITLE=Antigravity
ANTIGRAVITY_CDP_INPUT_ROOT_ID=antigravity.agentSidePanelInputBox
ANTIGRAVITY_SYNC_INTERVAL_MS=3000

# Audio / TTS
TTS_PROVIDER=internal
TTS_VOICE_ID=system-default
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
